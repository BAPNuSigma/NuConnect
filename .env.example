# Gmail (recommended): invite emails sent from your Gmail
# Use an App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=yourchapter@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional: Resend instead of Gmail
# RESEND_API_KEY=re_xxxx
# RESEND_FROM_EMAIL=NuConnect <noreply@yourdomain.com>
#   Leave RESEND_FROM_EMAIL unset to send from onboarding@resend.dev (works without domain verification).
#   If set, the address must use a domain you verified in Resend (e.g. yourdomain.com). Do not use Gmail here.

# Optional: 9 AM cron — set so only cron can call batch send (send Authorization: Bearer <CRON_SECRET>)
# CRON_SECRET=your-random-secret

# Optional: which semester to use when cron runs with no body (default: latest)
# CURRENT_SEMESTER_ID=1

# Optional: restrict Google Forms webhook to authorized callers
# GOOGLE_FORMS_WEBHOOK_SECRET=your-secret

# Optional: custom SQLite path (default: ./data/nuconnect.db)
# DATABASE_URL=./data/nuconnect.db
